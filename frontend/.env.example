# Base URL of the standalone Express backend.
# In dev this is http://localhost:3001 (see ../application-service-backend).
# In prod set it to the deployed backend URL; the frontend talks to it through
# the Next.js rewrite at /api/backend/* and never calls it cross-origin.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public URL of this Next.js app (used by OAuth callbacks and Paystack redirect URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000