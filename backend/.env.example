# --- Core (required) ---
PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/coded_app
JWT_SECRET=your_jwt_secret_here
GEMINI_API_KEY=your_gemini_api_key_here
AGNES_AI=your_agnes_ai_key_here

# --- Payments ---
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret_here

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- Session / auth (optional, these are the defaults) ---
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# --- HTTP (optional, these are the defaults) ---
HTTP_JSON_LIMIT=10mb
UPLOAD_MAX_BYTES=5242880
REQUEST_TIMEOUT_MS=30000
AI_REQUEST_TIMEOUT_MS=120000
LOG_FORMAT=dev
MAX_PRODUCTS_PER_VENDOR=20

# --- Rate limits (optional, these are the defaults) ---
RATE_LIMIT_AI_WINDOW_MS=60000
RATE_LIMIT_AI_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5

# --- AI models (optional, these are the defaults) ---
GEMINI_TEXT_MODEL=gemini-2.5-flash
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_IMAGE_SIZE=1024x1024
AGNES_TIMEOUT_MS=110000

# Shared hackathon campaign publishing API
CAMPAIGN_API_BASE_URL=https://api-hackathon.codedematrixtech.com
CAMPAIGN_API_MERCHANT_ID=rashida-tailors
CAMPAIGN_API_TEAM_SLUG=style-savant
CAMPAIGN_API_TIMEOUT_MS=30000

# --- Token costs & pricing (optional, these are the defaults) ---
TOKEN_COST_BACKGROUND_REMOVAL=5
TOKEN_COST_CAMPAIGN_COPY=5
TOKEN_COST_CAMPAIGN_IMAGE=10
TOKEN_LOW_BALANCE_THRESHOLD=100
TOKEN_PRICE_PER_1000=75
TOKEN_BUNDLE_SIZES=1000,5000,10000

# --- Object storage (product images) ---
# Driver: local | s3 | cloudinary. Default 'local' writes to disk, needs no creds.
STORAGE_DRIVER=local
# Absolute base URL the browser uses to reach files (local driver serves /uploads here).
STORAGE_PUBLIC_BASE_URL=http://localhost:3001
STORAGE_LOCAL_DIR=uploads
STORAGE_MAX_UPLOAD_BYTES=8388608
STORAGE_MAX_VIDEO_UPLOAD_BYTES=52428800
# S3 (when STORAGE_DRIVER=s3; also run: npm i @aws-sdk/client-s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
# Cloudinary (when STORAGE_DRIVER=cloudinary; also run: npm i cloudinary)
CLOUDINARY_URL=
CLOUDINARY_FOLDER=style-savant

# --- Hubtel mobile-money billing ---
HUBTEL_API_ID=
HUBTEL_API_KEY=
HUBTEL_MERCHANT_ACCOUNT_NUMBER=
HUBTEL_PAYMENT_URL=https://payproxyapi.hubtel.com/items/initiate
HUBTEL_STATUS_CHECK_URL=https://api-txnstatus.hubtel.com

# --- Billing plan (1 free month, then flat monthly fee; try-on = 2 tokens) ---
BILLING_MONTHLY_FEE_GHS=100
BILLING_MONTHLY_TOKENS=1200
BILLING_TRIAL_DAYS=30
TOKEN_COST_TRYON=2
TOKEN_COST_VIDEO_REQUEST=20
